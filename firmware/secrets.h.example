/*
  secrets.h.example
  ------------------
  1. Copy this file and rename it to "secrets.h"
  2. Fill in your real values below
  3. secrets.h is listed in .gitignore -- NEVER commit your real secrets.h
     to GitHub, share it in a zip you upload publicly, or paste it into
     a chat/forum when asking for help.

  If your old WiFi/MQTT password was ever pasted into a public place
  (forum, GitHub, chat, etc.), change that password now.
*/

#ifndef SECRETS_H
#define SECRETS_H

// ---------- WiFi ----------
#define WIFI_SSID   "YOUR_WIFI_NAME"
#define WIFI_PASS   "YOUR_WIFI_PASSWORD"

// ---------- MQTT (HiveMQ Cloud or any broker) ----------
#define MQTT_HOST   "your-cluster-id.s1.eu.hivemq.cloud"
#define MQTT_PORT   8883
#define MQTT_USER   "your_mqtt_username"
#define MQTT_PASS   "your_mqtt_password"
#define CLIENT_ID   "esp32_home_001"   // must be unique per device on the broker

#endif
